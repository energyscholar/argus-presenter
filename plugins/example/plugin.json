{
  "name": "example",
  "description": "Example domain bundle — a weather-status panel component and a city-grid map preset. Demonstrates a plugin that adds both a component and a map preset.",
  "requires": [],
  "components": ["weather"],
  "presets": { "map": ["city-grid"] },
  "fieldSchemas": {
    "weather": {
      "fields": [
        { "name": "title", "type": "string", "required": false },
        { "name": "metrics", "type": "array", "required": true,
          "items": { "type": "object", "fields": [
            { "name": "key", "type": "string", "required": true },
            { "name": "label", "type": "string", "required": true },
            { "name": "value", "type": "number", "required": true, "min": 0, "max": 100 }
          ] } }
      ]
    }
  }
}
